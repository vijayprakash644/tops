# ============================================================
# TopS.II Predictive Dialer Relay — Environment Configuration
# Copy this file to .env and fill in real values before deploy.
# ============================================================

# ----------------------------------------------------------
# API Server Base URLs (no trailing slash)
# ----------------------------------------------------------
TEST_BASE_URL=https://your-test-fqdn
PROD_BASE_URL=https://your-prod-fqdn

# ----------------------------------------------------------
# Active environment for index.php / call_start.php
# Set to PROD for production deployment.
# ----------------------------------------------------------
INDEX_ENV=TEST

# ----------------------------------------------------------
# API Keys for TopS.II (32-character alphanumeric)
# Found in TopS.II admin panel under Web-API settings.
# ----------------------------------------------------------
TEST_API_KEY=replace_with_test_key
PROD_API_KEY=replace_with_prod_key

# ----------------------------------------------------------
# IMPORTANT: Set to true before going live.
# When false, requests are logged but NOT sent to TopS.II.
# Always keep false in development / staging dry-runs.
# ----------------------------------------------------------
ENABLE_REAL_SEND=false

# ----------------------------------------------------------
# Optional: State & dedupe TTL tuning (defaults shown)
# ----------------------------------------------------------
# How long (seconds) to keep phone1 state while waiting for phone2 callback.
# PHONE1_STATE_TTL_SECONDS=600

# How long (seconds) a request is considered "in-flight" (blocks duplicate sends).
# REQUEST_PROCESSING_TTL_SECONDS=30

# How long (seconds) a completed request is protected from duplicate callbacks.
# REQUEST_DEDUPE_TTL_SECONDS=300
